# ============================================================
# ENVIRONMENT VARIABLES - Copy this file to .env and fill in
# ============================================================

# === KAGGLE CREDENTIALS ===
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_api_key

# === DATABASE SETTINGS ===
# SQLite (default - no setup needed)
DATABASE_URL=sqlite:///./database/medical_ai.db

# PostgreSQL (optional - for production)
# DATABASE_URL=postgresql://username:password@localhost:5432/medical_ai_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=medical_ai_db

# === MODEL SETTINGS ===
MODEL_SAVE_PATH=./models/saved_models
CHECKPOINT_PATH=./models/checkpoints
WEIGHTS_PATH=./models/model_weights

# === DATA PATHS ===
DATA_RAW_PATH=./data/raw
DATA_PROCESSED_PATH=./data/processed
DATA_AUGMENTED_PATH=./data/augmented
DATASET_PATH=./data/raw/chest_xray

# === TRAINING SETTINGS ===
IMAGE_SIZE=224
BATCH_SIZE=32
EPOCHS=50
LEARNING_RATE=0.0001
VALIDATION_SPLIT=0.2
RANDOM_SEED=42

# === MLFLOW SETTINGS ===
MLFLOW_TRACKING_URI=./logs/mlruns
MLFLOW_EXPERIMENT_NAME=medical_ai_experiments

# === STREAMLIT SETTINGS ===
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=0.0.0.0

# === LOGGING ===
LOG_LEVEL=INFO
LOG_FILE=./logs/medical_ai.log
